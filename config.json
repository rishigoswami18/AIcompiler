  "business_logic": [
    {
      "rule": "password_hashing",
      "description": "Passwords hashed with bcrypt; plaintext never stored"
    },
    {
      "rule": "jwt_authentication",
      "description": "All authenticated endpoints require valid JWT; 24h expiry"
    },
    {
      "rule": "owner_scoping",
      "description": "sales_rep sees only own records; manager and admin see all"
    },
    {
      "rule": "deal_stage_validation",
      "description": "Stage must be: lead, qualified, proposal, negotiation, closed_won, closed_lost"
    },
    {
      "rule": "deal_stage_transition",
      "description": "Forward-only pipeline movement; backward requires manager+"
    },
    {
      "rule": "contact_status_values",
      "description": "Status must be: active, inactive, lead, customer"
    },
    {
      "rule": "activity_type_values",
      "description": "Type must be: call, email, meeting, task, note"
    },
    {
      "rule": "refund_only_completed",
      "description": "Only completed payments can be refunded"
    },
    {
      "rule": "cascade_delete_protection",
      "description": "Company deletion sets company_id null on contacts and deals"
