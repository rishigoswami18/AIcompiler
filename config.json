{
  "meta": {
    "app_name": "build_a_crm_system_with_login_contacts_manageme",
    "description": "Deterministically generated crm application from natural language prompt.",
    "assumptions": [
      "Payments and invoices are excluded unless the prompt asks for them."
    ],
    "clarification_needed": []
  },
  "architecture": {
    "entities": [
      "contact",
      "companie"
    ],
    "modules": [
      "auth",
      "dashboard",
      "contacts",
      "companies"
    ],
    "flows": [
      "prompt -> intent_extraction",
      "intent_extraction -> system_design",
      "system_design -> schema_generation",
      "schema_generation -> validation_and_repair",
      "validation_and_repair -> artifact_generation"
    ]
  },
